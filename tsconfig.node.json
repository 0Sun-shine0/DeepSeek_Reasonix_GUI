{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "dist-electron",
    "rootDir": "src",
    "lib": ["ES2022"]
  },
  "include": ["src/main/**/*", "src/preload/**/*", "src/shared/**/*"]
}
